# BankNifty Observatory Platform — Configuration Reference
#
# Copy this file to .env for local development.
# Fill in real values. NEVER commit .env.
# Production: use deployment/env.example as the starting point.
#
# All keys use the BNO_ prefix.
# BNO_CONFIG_SCHEMA_VERSION must match the version the config loader expects.

# ── [INFRA] ───────────────────────────────────────────────────────────────────

BNO_ENV=development
# Valid: development | staging | production
# production rejects local-dev fallbacks (e.g. local_seed TOTP provider).

BNO_CONFIG_SCHEMA_VERSION=2
# version 1 — initial Phase-0 schema
# version 2 — Phase-1 contract: adds BNO_CHAIN_EXPIRIES (required)
# Mismatch causes a startup rejection.

BNO_LOG_LEVEL=INFO
# Valid: DEBUG | INFO | WARNING | ERROR | CRITICAL

BNO_DB_HOST=localhost
BNO_DB_PORT=5432
BNO_DB_NAME=bno
BNO_DB_USER=bno_app
BNO_DB_PASSWORD=REPLACE_ME
BNO_DB_POOL_MAX=10
BNO_DB_POOL_MIN=2

BNO_S3_BUCKET=REPLACE_ME
BNO_S3_REGION=ap-south-1
BNO_S3_PREFIX=raw/

BNO_DATA_DIR=./data
BNO_BUFFER_DIR=./data/buffer
# Buffer is written when DB is unavailable. Never purge manually.

# ── [SMARTAPI] ────────────────────────────────────────────────────────────────

BNO_SMARTAPI_API_KEY=REPLACE_ME
BNO_SMARTAPI_CLIENT_ID=REPLACE_ME
BNO_SMARTAPI_PASSWORD=REPLACE_ME
# Password is validated for presence only. Never logged or echoed.

BNO_SMARTAPI_TOTP_PROVIDER=local_seed
# Valid: local_seed (development only) | authenticator_app | secrets_manager
# production rejects local_seed at startup.

BNO_SMARTAPI_TOTP_SECRET=REPLACE_ME
# Used only when BNO_SMARTAPI_TOTP_PROVIDER=local_seed.
# Never logged.

BNO_SMARTAPI_TOKEN_REFRESH_BUFFER_MINUTES=10
# Re-login this many minutes before token expiry.

# ── [NOTIFY] ─────────────────────────────────────────────────────────────────

BNO_TELEGRAM_BOT_TOKEN=REPLACE_ME
# Never logged. Validated for presence only.

BNO_TELEGRAM_CHAT_ID=REPLACE_ME
# The dedicated BankNifty Observatory Telegram channel ID.

BNO_ALERT_MIN_LEVEL=ERROR
# INFO and WARNING queue for the daily report.
# ERROR and CRITICAL route immediately to Telegram.

BNO_ALERT_THROTTLE_SECONDS=60
# De-duplicate window. Identical alerts within this window are suppressed.

# ── [MARKET] ─────────────────────────────────────────────────────────────────

BNO_INSTRUMENT_SYMBOL=BANKNIFTY
BNO_CHAIN_POLL_INTERVAL_S=5
BNO_SESSION_OPEN_TIME=09:15
BNO_SESSION_CLOSE_TIME=15:30
BNO_SESSION_CLOSE_BUFFER_MIN=15
# Post-session batch jobs wait this many minutes after close before starting.

BNO_TIMEZONE=Asia/Kolkata

# ── [CHAIN] ───────────────────────────────────────────────────────────────────

BNO_CHAIN_EXPIRIES=26JUN2026,30JUN2026
# Comma-separated list of active BankNifty expiries in DDMMMYYYY format.
# REQUIRED. No default — expiries roll weekly/monthly and must be set explicitly.
# Update every Thursday evening before the weekly expiry.
# Example for multi-expiry: "26JUN2026,30JUN2026,31JUL2026"

BNO_CHAIN_WINDOW_STEPS=15
# Number of backbone steps on each side of ATM.
# 15 steps × 500-pt backbone = ±7500-pt window (31 strikes total per side).

BNO_CHAIN_STEP_SIZE=500
# Backbone grid spacing in index points. Matches NSE BankNifty liquid strike ladder.

# ── [RESEARCH] ────────────────────────────────────────────────────────────────

BNO_COST_MODEL_VERSION=
# Required before labeling can run. Set only after ratification in DECISION_LOG.
# Empty value keeps the labeling service dormant.

BNO_METHODOLOGY_VERSION=
# Active methodology version for derivation.

BNO_OPPORTUNITY_HORIZON_GRID_MS=60000,300000,900000,1800000,3600000
# Comma-separated forward horizon values in milliseconds.
# Used by the labeling framework once cost model is ratified.

# ── [FLAGS] ───────────────────────────────────────────────────────────────────

BNO_STRATEGY_ACTIVE=false
# Hard off. Enabling requires a stage-authorization token per STAGE_GATE_POLICY.
# This flag controls the entire trading module family.

BNO_LABELING_ACTIVE=false
# Controls the labeling pipeline. Requires BNO_COST_MODEL_VERSION to be set.
# Enabling without a ratified cost model is rejected at startup.
