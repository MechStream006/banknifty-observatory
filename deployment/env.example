# BankNifty Observatory — Production Environment Configuration
#
# Usage on server:
#   sudo cp deployment/env.example /etc/banknifty-observatory/discovery.env
#   sudo nano /etc/banknifty-observatory/discovery.env   # fill in real values
#   sudo chmod 640 /etc/banknifty-observatory/discovery.env
#   sudo chown root:bno /etc/banknifty-observatory/discovery.env
# 640 (rw-r-----): root owns and writes; bno group reads (required for manual
# verification via "sudo -u bno cat"). Not world-readable.
#
# The systemd service loads this file via EnvironmentFile=.
# NEVER commit a filled-in version of this file.
#
# Production constraints enforced at startup:
#   - BNO_ENV must be "production"
#   - BNO_SMARTAPI_TOTP_PROVIDER must NOT be "local_seed"
#   - BNO_CHAIN_EXPIRIES must be set (no default)
#   - BNO_CONFIG_SCHEMA_VERSION must match the codebase (currently 2)
#   - BNO_STRATEGY_ACTIVE=true is rejected at startup (stage gate required)

# ── [INFRA] ───────────────────────────────────────────────────────────────────

BNO_ENV=production
BNO_CONFIG_SCHEMA_VERSION=2
BNO_LOG_LEVEL=INFO

BNO_DB_HOST=localhost
BNO_DB_PORT=5432
BNO_DB_NAME=bno
BNO_DB_USER=bno_app
BNO_DB_PASSWORD=REPLACE_ME
BNO_DB_POOL_MAX=10
BNO_DB_POOL_MIN=2

BNO_S3_BUCKET=REPLACE_ME
# Example: your-observatory-raw-data-bucket
BNO_S3_REGION=ap-south-1
BNO_S3_PREFIX=raw/

BNO_DATA_DIR=/srv/bno/data
BNO_BUFFER_DIR=/srv/bno/data/buffer

# ── [SMARTAPI] ────────────────────────────────────────────────────────────────

BNO_SMARTAPI_API_KEY=REPLACE_ME
BNO_SMARTAPI_CLIENT_ID=REPLACE_ME
BNO_SMARTAPI_PASSWORD=REPLACE_ME

BNO_SMARTAPI_TOTP_PROVIDER=authenticator_app
# Production must use "authenticator_app" or "secrets_manager".
# "local_seed" is rejected at startup in production.

BNO_SMARTAPI_TOTP_SECRET=
# Leave empty when BNO_SMARTAPI_TOTP_PROVIDER=authenticator_app.
# Set only when using local_seed (development only).

BNO_SMARTAPI_TOKEN_REFRESH_BUFFER_MINUTES=10

# ── [NOTIFY] ─────────────────────────────────────────────────────────────────

BNO_TELEGRAM_BOT_TOKEN=REPLACE_ME
BNO_TELEGRAM_CHAT_ID=REPLACE_ME
BNO_ALERT_MIN_LEVEL=ERROR
BNO_ALERT_THROTTLE_SECONDS=60

# ── [MARKET] ─────────────────────────────────────────────────────────────────

BNO_INSTRUMENT_SYMBOL=BANKNIFTY
BNO_CHAIN_POLL_INTERVAL_S=5
BNO_SESSION_OPEN_TIME=09:15
BNO_SESSION_CLOSE_TIME=15:30
BNO_SESSION_CLOSE_BUFFER_MIN=15
BNO_TIMEZONE=Asia/Kolkata

# ── [CHAIN] — Update weekly every Thursday evening ────────────────────────────

BNO_CHAIN_EXPIRIES=REPLACE_ME
# REQUIRED. Comma-separated BankNifty expiries in DDMMMYYYY format.
# Example: BNO_CHAIN_EXPIRIES=26JUN2026,03JUL2026
# Update this every Thursday evening for the following week's active expiries.
# Include both the expiring-soon weekly AND the next weekly.

BNO_CHAIN_WINDOW_STEPS=15
BNO_CHAIN_STEP_SIZE=500

# ── [RESEARCH] ────────────────────────────────────────────────────────────────

BNO_COST_MODEL_VERSION=
# Required before labeling. Empty keeps labeling dormant.

BNO_METHODOLOGY_VERSION=
BNO_OPPORTUNITY_HORIZON_GRID_MS=60000,300000,900000,1800000,3600000

# ── [FLAGS] — These are safety gates; do not enable without stage sign-off ────

BNO_STRATEGY_ACTIVE=false
BNO_LABELING_ACTIVE=false
